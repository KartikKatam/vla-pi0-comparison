# Source on H100 cloud nodes.
export XLA_PYTHON_CLIENT_MEM_FRACTION=0.92
export XLA_PYTHON_CLIENT_PREALLOCATE=false
export MUJOCO_GL=egl
export WANDB_PROJECT=libero-vla-analysis

# Provider-neutral mount root used by scripts/cloud/*.
export WORKSPACE_DIR=/workspace/libero-vla

# Pinned to e4580662 (last known-good commit for pi0_fast_libero, per CMPE188 scaffold notes).
# Re-evaluate after the smoke test on Lambda passes; bump only with a recorded reason.
export OPENPI_REF=e4580662
# Docker tags can't contain certain chars; the short SHA is safe.
export TRAIN_IMAGE=libero-vla/openpi-train:${OPENPI_REF}
export EVAL_IMAGE=libero-vla/libero-eval:${OPENPI_REF}
